#!/usr/bin/env python3.11

import getopt
import sys
import ninja_vault as njv


def usage():
    print("""
py-njv (ninja-vault); Recursive directory encryption and decryption with GnuPG

[+] Version: $version
    Author:  Fabrice Sommavilla
    URL:     https://github.com/flasomm/ninja-vault.git

Usage: py-njv -e|-d <directory> [options]

Options:
    -e, --encrypt <directory>   - Recursively encrypt all files in
                                  <directory> and all subdirectories.
    -d, --decrypt <directory>   - Recursively decrypt all files in
                                  <directory> and all subdirectories.
    --sign <directory>          - Recursively sign all files in <directory>
                                  and all subdirectories.
    --verify <directory>        - Recursively verify all GnuPG signatures
                                  in <directory>.
    -K, --Key-id <id>           - Specify GnuPG key ID, or key-matching
                                  string. This overrides the use_key value
                                  in ~/.py_njvrc
    -D, --Default-key           - Use the key that GnuPG defines as the
                                  default (i.e. the key that is specified
                                  by the default-key option in
                                  ~/.gnupg/options).
    -g, --gnupg-dir <dir>       - Specify a path to a .gnupg directory for
                                  gpg keys (the default is ~/.gnupg if this
                                  option is not used).
    --no-delete                 - Keep original files after encrypt/decrypt.
    --dry-run                   - Preview actions without changing files.
    --verbose                   - Run in verbose mode.
    -V, --Version               - print version.
    -h, --help                  - print help.

    """)
    sys.exit()


def main(argv):
    usage_message = 'py-njv -e|-d <directory> [options]'
    option_args = [
        "encrypt=", "decrypt=", "sign=", "verify=", "Key-id=", "Default-key",
        "gnupg-dir=", "user-homedir=", "no-delete", "dry-run", "verbose", "Version", "help"
    ]
    try:
        opts, args = getopt.getopt(argv, "e:d:K:Dg:u:Vh", option_args)
        if len(opts) <= 0:
            print(usage_message)
            exit(1)
    except getopt.GetoptError:
        print(usage_message)
        sys.exit(2)

    # Collect options before dispatching
    action = None
    action_arg = None
    key_id = None
    home_dir = None
    use_default_key = False
    delete_original = True
    dry_run = False
    verbose = False

    for opt, arg in opts:
        if opt in ('-h', '--help'):
            usage()
        elif opt in ('-V', '--Version'):
            njv.get_version()
            sys.exit(0)
        elif opt in ('-e', '--encrypt'):
            action, action_arg = 'encrypt', arg
        elif opt in ('-d', '--decrypt'):
            action, action_arg = 'decrypt', arg
        elif opt == '--sign':
            action, action_arg = 'sign', arg
        elif opt == '--verify':
            action, action_arg = 'verify', arg
        elif opt in ('-K', '--Key-id'):
            key_id = arg
        elif opt in ('-D', '--Default-key'):
            use_default_key = True
        elif opt in ('-g', '--gnupg-dir', '-u', '--user-homedir'):
            home_dir = arg
        elif opt == '--no-delete':
            delete_original = False
        elif opt == '--dry-run':
            dry_run = True
        elif opt == '--verbose':
            verbose = True

    if action is None:
        print(usage_message)
        sys.exit(1)

    if use_default_key:
        key_id = njv.get_default_key(home_dir=home_dir)

    if action == 'encrypt':
        njv.encrypt_dir(
            action_arg,
            key_id=key_id,
            home_dir=home_dir,
            verbose=verbose,
            delete_original=delete_original,
            dry_run=dry_run,
        )
    elif action == 'decrypt':
        njv.decrypt_dir(
            action_arg,
            home_dir=home_dir,
            verbose=verbose,
            delete_original=delete_original,
            dry_run=dry_run,
        )
    elif action == 'sign':
        njv.sign_dir(action_arg, key_id=key_id, home_dir=home_dir, verbose=verbose)
    elif action == 'verify':
        njv.verify_dir(action_arg, home_dir=home_dir, verbose=verbose)


if __name__ == "__main__":
    main(sys.argv[1:])
